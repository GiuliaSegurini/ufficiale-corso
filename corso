<!DOCTYPE html>
<html lang="it">
<head>
<metà charset="UTF-8">
<metà name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ufficiale di Macchina STCW III/1 — Prepara l'esame con metodo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #05080f;
  --bg2: #080d1a;
  --bg3: #0a1020;
  --navy: #0d1b3e;
  --orange: #e8660a;
  --orange2: #ff7a1a;
  --orange-glow: rgba(232,102,10,0.15);
  --orange-dim: rgba(232,102,10,0.07);
  --steel: #8fa3c0;
  --steel-light: #b8cde0;
  --cream: #f0ece3;
  --white: #f4f4f2;
  --muted: #4a6080;
  --border: rgba(143,163,192,0.12);
  --border-orange: rgba(232,102,10,0.2);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Barlow', sans-serif; background: var(--bg); color: var(--white); overflow-x: hidden; }
a { text-decoration: none; }

/* CANVAS */
#particles-canvas { position: fixed; top:0; left:0; width:100%; height:100%; pointer-events:none; z-index:0; opacity:0.4; }

/* NAV */
nav {
  position: fixed; top:0; left:0; right:0; z-index:100;
  padding: 18px 6vw;
  display: flex; justify-content: space-between; align-items: center;
  background: rgba(5,8,15,0.75);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
}
.nav-logo {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  font-weight: 500;
  color: var(--orange);
  letter-spacing: 0.05em;
}
.nav-logo span { color: var(--steel); }
.nav-cta {
  background: var(--orange);
  color: #fff;
  font-size: 14px;
  font-weight: 500;
  padding: 10px 24px;
  border-radius: 6px;
  transition: opacity 0.2s, transform 0.2s;
}
.nav-cta:hover { opacity:0.88; transform:translateY(-1px); }

/* HERO */
.hero {
  min-height: 100vh;
  display: flex; flex-direction: column;
  justify-content: center; align-items: flex-start;
  padding: 140px 6vw 100px;
  position: relative; z-index:1;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--orange-dim);
  border: 1px solid var(--border-orange);
  border-radius: 4px;
  padding: 7px 16px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: var(--orange);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 32px;
}
.hero-badge::before { content:''; width:7px; height:7px; border-radius:50%; background:var(--orange); animation: blink 2s ease-in-out infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.hero h1 {
  font-family: 'Barlow Condensed', sans-serif; letter-spacing: 0.02em;
  font-size: clamp(48px, 7.5vw, 96px);
  font-weight: 900;
  line-height: 1.06;
  color: var(--cream);
  max-width: 900px;
  margin-bottom: 28px;
}
.hero h1 .acc {
  background: linear-gradient(135deg, #e8660a 0%, #ff9a3c 50%, #e8660a 100%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientShift 3s ease infinite;
}
@keyframes gradientShift {
  0%{ background-position: 0% center; }
  50%{ background-position: 100% center; }
  100%{ background-position: 0% center; }
}
.hero h1 .acc2 { color: var(--steel-light); }
.hero-sub {
  font-size: clamp(16px, 1.8vw, 20px);
  color: var(--steel);
  line-height: 1.75;
  max-width: 600px;
  margin-bottom: 44px;
}
.hero-stats {
  display: flex; flex-wrap: wrap; gap: 32px;
  margin-bottom: 48px;
}
.hero-stat { display:flex; flex-direction:column; gap:4px; }
.hero-stat-num {
  font-family: 'Barlow Condensed', sans-serif; letter-spacing: 0.02em;
  font-size: 36px; font-weight: 900;
  color: var(--orange); line-height:1;
}
.hero-stat-label { font-size: 13px; color: var(--muted); }
.hero-buttons { display:flex; gap:14px; flex-wrap:wrap; }
.btn-primary {
  display: inline-flex; align-items:center; gap:10px;
  background: var(--orange); color: #fff;
  font-size: 17px; font-weight: 500;
  padding: 17px 36px; border-radius: 6px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.btn-primary:hover { transform:translateY(-3px); box-shadow: 0 12px 40px rgba(232,102,10,0.3); }
.btn-ghost {
  display: inline-flex; align-items:center; gap:10px;
  background: transparent; color: var(--steel-light);
  font-size: 17px; font-weight: 400;
  padding: 17px 32px; border-radius: 6px;
  border: 1px solid var(--border);
  transition: background 0.2s, transform 0.2s;
}
.btn-ghost:hover { background: rgba(143,163,192,0.06); transform:translateY(-2px); }
.hero-scroll { position:absolute; bottom:36px; left:6vw; display:flex; align-items:center; gap:10px; color:rgba(143,163,192,0.35); font-size:12px; letter-spacing:0.1em; text-transform:uppercase; }
.scroll-bar { width:40px; height:1px; background: linear-gradient(to right, rgba(232,102,10,0.6), transparent); }

/* STRIP */
.strip {
  position:relative; z-index:1;
  border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  background: rgba(232,102,10,0.04);
  padding: 22px 6vw;
  display:flex; flex-wrap:wrap; gap:10px 28px; align-items:center;
}
.strip-label { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; flex-shrink:0; }
.strip-pills { display:flex; flex-wrap:wrap; gap:8px; }
.strip-pill {
  background: rgba(143,163,192,0.06); border:1px solid var(--border);
  color: var(--steel-light); font-size:12px; font-weight:500;
  padding:5px 14px; border-radius:4px;
}

/* SECTIONS */
section { position:relative; z-index:1; padding:110px 6vw; }
.section-eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size:11px; font-weight:500; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--orange); margin-bottom:16px; opacity:0.9;
}
h2.section-title {
  font-family: 'Barlow Condensed', sans-serif; letter-spacing: 0.02em;
  font-size: clamp(32px, 4.5vw, 58px);
  font-weight: 900; line-height: 1.1; color: var(--cream);
}
h2.section-title .acc { color: var(--orange); }
h2.section-title .acc2 { color: var(--steel-light); }
.glow-line { width:60px; height:2px; background:var(--orange); border-radius:2px; margin-top:24px; box-shadow:0 0 16px rgba(232,102,10,0.5); }

/* PROBLEMA */
.problema-section { background: var(--bg2); }
.problema-intro { font-size:18px; color:var(--steel); line-height:1.75; max-width:min(660px,100%); margin-top:22px; margin-bottom:60px; }
.problema-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:18px; }
.problema-card {
  background: rgba(143,163,192,0.03); border:1px solid var(--border);
  border-radius:8px; padding:32px;
  transition: border-color 0.3s, transform 0.3s, background 0.3s;
}
.problema-card:hover { border-color:rgba(232,102,10,0.3); background:var(--orange-dim); transform:translateY(-4px); }
.problema-card h3 { font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; color:var(--cream); margin-bottom:10px; }
.problema-card p { font-size:14px; color:var(--steel); line-height:1.7; }
.prob-tag {
  display:inline-block; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase;
  background:var(--orange-dim); border:1px solid var(--border-orange);
  color:var(--orange); padding:4px 12px; border-radius:3px; margin-bottom:14px;
}

/* ESAME */
.esame-section { background:var(--bg); }
.esame-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:18px; margin-top:60px; }
.esame-card {
  background:var(--orange-dim); border:1px solid var(--border-orange);
  border-radius:8px; padding:32px; text-align:center;
  transition: transform 0.3s, border-color 0.3s;
}
.esame-card:hover { transform:translateY(-4px); border-color:rgba(232,102,10,0.5); }
.esame-num { font-family:'Barlow Condensed',sans-serif; font-size:52px; font-weight:900; color:var(--orange); line-height:1; margin-bottom:10px; text-shadow:0 0 24px rgba(232,102,10,0.3); }
.esame-label { font-size:13px; color:var(--steel); line-height:1.5; }
.esame-note { font-size:16px; color:var(--steel); line-height:1.8; max-width:min(680px,100%); margin-top:24px; }

/* ENGLISH */
.english-section { background:var(--bg3); }
.english-intro { font-size:17px; color:var(--steel); line-height:1.75; max-width:min(640px,100%); margin-top:20px; margin-bottom:50px; }
.vocab-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(min(300px,100%),1fr)); gap:10px; margin-top:40px; }
.vocab-card {
  background:rgba(13,27,62,0.6); border:1px solid rgba(143,163,192,0.15);
  border-radius:8px; padding:16px 20px;
  display:flex; align-items:flex-start; gap:12px;
  transition: border-color 0.3s, transform 0.2s;
  min-width:0;
}
.vocab-card:hover { border-color:rgba(232,102,10,0.3); transform:translateY(-2px); }
.vocab-en {
  font-family:'JetBrains Mono',monospace; font-size:13px; font-weight:500;
  color:var(--orange); flex-shrink:0; min-width:160px; padding-top:2px;
}
.vocab-it { font-size:13px; color:var(--steel); line-height:1.5; }
.english-phrase-block {
  margin-top:40px; background:rgba(13,27,62,0.5); border:1px solid var(--border);
  border-radius:8px; padding:28px 24px;
}
.english-phrase-block h3 { font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:700; color:var(--cream); margin-bottom:24px; }
.phrase-item { padding:12px 0; border-bottom:1px solid var(--border); display:flex; flex-direction:column; gap:4px; }
.phrase-item:last-child { border-bottom:none; }
.phrase-en { font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--orange2); }
.phrase-it { font-size:13px; color:var(--steel); }

/* MODULI */
.moduli-section { background:var(--bg2); }
.moduli-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:18px; margin-top:56px; }
.modulo-card {
  background:rgba(255,255,255,0.02); border:1px solid var(--border);
  border-radius:8px; padding:36px; position:relative; overflow:hidden;
  transition: border-color 0.3s, transform 0.3s;
}
.modulo-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:var(--orange); opacity:0; transition:opacity 0.3s; }
.modulo-card:hover { border-color:rgba(232,102,10,0.3); transform:translateY(-4px); }
.modulo-card:hover::before { opacity:1; }
.modulo-num { font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:500; color:var(--orange); letter-spacing:0.12em; text-transform:uppercase; margin-bottom:12px; }
.modulo-card h3 { font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; color:var(--cream); margin-bottom:12px; }
.modulo-card ul { list-style:none; }
.modulo-card ul li { display:flex; align-items:flex-start; gap:8px; font-size:13px; color:var(--steel); padding:5px 0; line-height:1.5; border-bottom:1px solid rgba(143,163,192,0.07); }
.modulo-card ul li:last-child { border-bottom:none; }
.modulo-card ul li::before { content:'_'; color:var(--orange); font-family:'JetBrains Mono',monospace; flex-shrink:0; }

/* DOMANDE TIPICHE */
.domande-section { background:var(--bg); }
.domande-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:50px; --dq-cols:1fr 1fr; }
@media(max-width:min(700px,100%)){ .domande-grid { grid-template-columns:1fr; } }
.domanda-card {
  background:rgba(13,27,62,0.5); border:1px solid var(--border);
  border-radius:8px; padding:22px 26px;
  transition: border-color 0.3s, transform 0.2s;
}
.domanda-card:hover { border-color:rgba(232,102,10,0.3); transform:translateY(-2px); }
.domanda-cat { font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--orange); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:8px; }
.domanda-card p { font-size:14px; color:var(--steel-light); line-height:1.6; }

/* PRICING */
.pricing-section { background:var(--bg2); }
.pricing-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:22px; max-width:min(860px,100%); margin-top:60px; }
.plan-card { border-radius:10px; padding:44px; position:relative; transition:transform 0.3s; }
.plan-card:hover { transform:translateY(-5px); }
.plan-base { background:rgba(255,255,255,0.02); border:1px solid var(--border); }
.plan-pro {
  background: var(--orange);
  border: none;
  position: relative;
  overflow: hidden;
}
.plan-pro::before {
  content: '';
  position: absolute;
  inset: -2px;
  background: linear-gradient(135deg, #ff9a3c, #e8660a, #ff6b00, #e8660a);
  background-size: 300% 300%;
  animation: borderGlow 4s ease infinite;
  z-index: -1;
  border-radius: 12px;
}
@keyframes borderGlow {
  0%{ background-position: 0% 50%; }
  50%{ background-position: 100% 50%; }
  100%{ background-position: 0% 50%; }
}
.plan-badge { position:absolute; top:-14px; left:50%; transform:translateX(-50%); background:var(--bg); color:var(--orange); font-size:11px; font-weight:500; padding:5px 18px; border-radius:30px; border:1px solid var(--border-orange); white-space:nowrap; font-family:'JetBrains Mono',monospace; letter-spacing:0.06em; }
.plan-label { font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; margin-bottom:14px; }
.plan-base .plan-label { color:rgba(143,163,192,0.5); }
.plan-pro .plan-label { color:rgba(5,8,15,0.6); }
.plan-name { font-family:'Barlow Condensed',sans-serif; font-size:34px; font-weight:900; margin-bottom:6px; }
.plan-base .plan-name { color:var(--cream); }
.plan-pro .plan-name { color:#05080f; }
.plan-tagline { font-size:13px; margin-bottom:28px; }
.plan-base .plan-tagline { color:rgba(143,163,192,0.5); }
.plan-pro .plan-tagline { color:rgba(5,8,15,0.6); }
.plan-price { display:flex; align-items:baseline; gap:4px; margin-bottom:6px; }
.price-cur { font-size:20px; font-weight:400; }
.plan-base .price-cur { color:rgba(240,236,227,0.4); }
.plan-pro .price-cur { color:rgba(5,8,15,0.5); }
.price-num { font-family:'Barlow Condensed',sans-serif; font-size:64px; font-weight:900; line-height:1; }
.plan-base .price-num { color:var(--cream); }
.plan-pro .price-num { color:#05080f; }
.price-strike { font-size:17px; text-decoration:line-through; margin-left:6px; }
.plan-base .price-strike { color:rgba(240,236,227,0.25); }
.plan-pro .price-strike { color:rgba(5,8,15,0.3); }
.price-period { font-size:12px; margin-bottom:28px; }
.plan-base .price-period { color:rgba(143,163,192,0.4); }
.plan-pro .price-period { color:rgba(5,8,15,0.45); }
.plan-divider { height:1px; margin:18px 0; }
.plan-base .plan-divider { background:var(--border); }
.plan-pro .plan-divider { background:rgba(5,8,15,0.15); }
.plan-features { list-style:none; }
.plan-features li { display:flex; align-items:flex-start; gap:10px; font-size:14px; padding:8px 0; line-height:1.5; }
.plan-base .plan-features li { color:var(--steel); }
.plan-pro .plan-features li { color:#05080f; }
.plan-features li .ic { flex-shrink:0; font-family:'JetBrains Mono',monospace; }
.plan-base .plan-features li .ic { color:var(--orange); }
.plan-cta { display:block; text-align:center; padding:16px; border-radius:6px; font-size:16px; font-weight:500; margin-top:28px; transition:transform 0.2s, opacity 0.2s, box-shadow 0.2s; }
.plan-cta:hover { transform:translateY(-2px); opacity:0.88; }
.plan-base .plan-cta { background:var(--orange-dim); color:var(--orange); border:1px solid var(--border-orange); }
.plan-pro .plan-cta { background:#05080f; color:var(--orange); box-shadow:0 8px 24px rgba(5,8,15,0.3); }

/* STCW */
.stcw-section { background:var(--navy); }
.stcw-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:18px; margin-top:50px; }
.stcw-card { background:rgba(232,102,10,0.05); border:1px solid var(--border-orange); border-radius:8px; padding:28px; }
.stcw-card h3 { font-family:'JetBrains Mono',monospace; font-size:14px; font-weight:500; color:var(--orange); margin-bottom:8px; letter-spacing:0.06em; }
.stcw-card p { font-size:13px; color:var(--steel); line-height:1.65; }

/* FINAL CTA */
.final-cta { position:relative; z-index:1; background:#060b10; padding:130px 6vw; text-align:center; overflow:hidden; }
.final-cta::before { content:''; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:700px; height:700px; background:radial-gradient(circle, rgba(232,102,10,0.07) 0%, transparent 70%); pointer-events:none; }
.final-cta h2 { font-family:'Barlow Condensed',sans-serif; font-size:clamp(38px,5.5vw,70px); font-weight:900; color:var(--cream); line-height:1.1; margin-bottom:22px; position:relative; }
.final-cta p { font-size:18px; color:var(--steel); line-height:1.7; max-width:min(520px,100%); margin:0 auto 48px; position:relative; }
.final-cta .big-cta { display:inline-flex; align-items:center; gap:12px; background:var(--orange); color:#fff; font-size:20px; font-weight:500; padding:22px 52px; border-radius:8px; transition:transform 0.2s, box-shadow 0.2s; position:relative; }
.final-cta .big-cta:hover { transform:translateY(-4px); box-shadow:0 16px 50px rgba(232,102,10,0.3); }

/* FOOTER */
footer { position:relative; z-index:1; background:var(--bg); padding:28px 6vw; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px; border-top:1px solid var(--border); }
footer p { font-size:12px; color:rgba(143,163,192,0.25); font-family:'JetBrains Mono',monospace; }

/* REVEAL */
.reveal { opacity:1; transform:translateY(0); transition:opacity 0.7s ease, transform 0.7s ease; }
.reveal.visible { opacity:1; transform:translateY(0); }
.js-ready .reveal { opacity:0; transform:translateY(28px); }
.js-ready .reveal.visible { opacity:1; transform:translateY(0); }

/* COUNTER GLOW */
.esame-num, .stat-num {
  text-shadow: 0 0 30px rgba(232,102,10,0.4);
}

/* HERO ANIM */
@keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
.hero-badge { animation:fadeUp 0.7s ease forwards; }
.hero h1 { animation:fadeUp 0.7s 0.1s ease both; }
.hero-sub { animation:fadeUp 0.7s 0.2s ease both; }
.hero-stats { animation:fadeUp 0.7s 0.28s ease both; }
.hero-buttons { animation:fadeUp 0.7s 0.36s ease both; }

@media(max-width:min(600px,100%)){ section{padding:80px 5vw;} .plan-card{padding:36px 26px;} }
@media(max-width:min(768px,100%)){ .about-resp { grid-template-columns:1fr !important; gap:40px !important; } }

/* ============ MOBILE RESPONSIVE ============ */
@media (max-width: 768px) {
  /* NAV */
  nav { padding: 14px 5vw; }
  .nav-logo { font-size: 12px; }
  .nav-cta { padding: 8px 16px; font-size: 13px; }

  /* HERO */
  .hero { padding: 100px 5vw 70px; align-items: flex-start; }
  .hero h1 { font-size: clamp(38px, 10vw, 60px); }
  .hero-sub { font-size: 15px; }
  .hero-stats { gap: 20px; }
  .hero-stat-num { font-size: 28px; }
  .hero-buttons { flex-direction: column; gap: 12px; }
  .btn-primary, .btn-ghost { width: 100%; justify-content: center; font-size: 15px; padding: 15px 24px; }

  /* ENGINE CANVAS */
  #engine-canvas { height: 260px !important; }

  /* MONITOR OVERLAY */
  [style*="justify-content:flex-end"][style*="padding:0 6vw"] {
    justify-content: center !important;
    padding: 0 4vw !important;
    align-items: flex-end !important;
    padding-bottom: 16px !important;
  }

  /* STRIP */
  .strip { padding: 16px 5vw; gap: 8px 16px; }
  .strip-pill { font-size: 11px; padding: 4px 10px; }

  /* SECTIONS */
  section { padding: 70px 5vw !important; }

  /* H2 */
  h2.section-title { font-size: clamp(28px, 7vw, 44px) !important; }

  /* PAIN POINTS */
  [style*="grid-template-columns:repeat(auto-fit,minmax(300px,1fr))"] {
    grid-template-columns: 1fr !important;
  }

  /* PHOTO STRIP */
  [style*="--photo-cols"] {
    grid-template-columns: 1fr !important;
    height: auto !important;
  }
