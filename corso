};

function QDraw() {
  var q   = QZ.qs[QZ.cur];
  var sEl = document.getElementById('QS');
  var bEl = document.getElementById('QB');
  var cEl = document.getElementById('QT');
  var qEl = document.getElementById('QQ');
  var fEl = document.getElementById('QF');
  var nEl = document.getElementById('QN');
  if (!sEl) return;
  sEl.textContent      = String(QZ.cur + 1).padStart(2,'0') + '/08';
  bEl.style.width      = ((QZ.cur + 1) / 8 * 100) + '%';
  cEl.textContent      = q.c;
  qEl.textContent      = q.q;
  fEl.style.display    = 'none';
  nEl.style.display    = 'none';
  nEl.style.opacity    = '1';
  QZ.done              = false;

  var opts = document.getElementById('QO');
  opts.innerHTML = '';
  for (var i = 0; i < q.o.length; i++) {
    var b = document.createElement('button');
    b.textContent = q.o[i];
    b.setAttribute('data-qi', String(i));
    b.style.cssText = 'width:100%;text-align:left;background:rgba(143,163,192,0.05);border:1px solid rgba(143,163,192,0.15);color:#b8cde0;padding:13px 16px;border-radius:6px;font-size:14px;cursor:pointer;display:block;margin-bottom:6px;font-family:Barlow,sans-serif;line-height:1.4;transition:background .15s,border-color .15s;box-sizing:border-box;';
    b.onmouseover = function () { if (!QZ.done) { this.style.background = 'rgba(232,102,10,0.1)'; this.style.borderColor = 'rgba(232,102,10,0.4)'; } };
    b.onmouseout  = function () { if (!QZ.done) { this.style.background = 'rgba(143,163,192,0.05)'; this.style.borderColor = 'rgba(143,163,192,0.15)'; } };
    b.addEventListener('click', (function(idx){ return function(){ QAns(idx); }; })(i));
    opts.appendChild(b);
  }
}

function QAns(i) {
  if (QZ.done) return;
  QZ.done = true;
  var q    = QZ.qs[QZ.cur];
  var cat  = q.c;
  if (!QZ.cats[cat]) QZ.cats[cat] = { ok: 0, n: 0 };
  QZ.cats[cat].n++;

  var all  = document.getElementById('QO').querySelectorAll('button');
  for (var j = 0; j < all.length; j++) { all[j].style.cursor = 'default'; }

  var btn = all[i];
  var fb  = document.getElementById('QF');

  if (i === q.k) {
    QZ.score++;
    QZ.cats[cat].ok++;
    btn.style.background  = 'rgba(127,201,176,0.15)';
    btn.style.borderColor = 'rgba(127,201,176,0.6)';
    btn.style.color       = '#7fc9b0';
    fb.style.cssText = 'display:block;margin-top:14px;padding:14px 18px;border-radius:6px;background:rgba(127,201,176,0.07);border:1px solid rgba(127,201,176,0.25);color:#7fc9b0;font-size:14px;line-height:1.65;';
    fb.innerHTML = '<strong>&#10003; Corretto.</strong> ' + q.e;
  } else {
    btn.style.background  = 'rgba(232,102,10,0.12)';
    btn.style.borderColor = 'rgba(232,102,10,0.5)';
    btn.style.color       = '#e8660a';
    all[q.k].style.background  = 'rgba(127,201,176,0.1)';
    all[q.k].style.borderColor = 'rgba(127,201,176,0.4)';
    all[q.k].style.color       = '#7fc9b0';
    fb.style.cssText = 'display:block;margin-top:14px;padding:14px 18px;border-radius:6px;background:rgba(232,102,10,0.06);border:1px solid rgba(232,102,10,0.25);color:#8fa3c0;font-size:14px;line-height:1.65;';
    fb.innerHTML = '<strong>&#10007; Risposta errata.</strong> ' + q.e;
  }

  var nEl = document.getElementById('QN');
  nEl.querySelector('button').textContent = (QZ.cur < 7) ? 'Prossima \u2192' : 'Vedi risultato \u2192';
  nEl.style.display = 'block';
}

function QNext() {
  QZ.cur++;
  if (QZ.cur < 8) { QDraw(); } else { QFine(); }
}

function QFine() {
  document.getElementById('QC').style.display = 'none';
  var qr = document.getElementById('QR');
  qr.style.display = 'block';
  var eg = document.getElementById('QR-email');
  var rc = document.getElementById('QR-content');
  if (eg) eg.style.display = 'block';
  if (rc) rc.style.display = 'none';
}

function QShowContent() {
  var s   = QZ.score;
  var lbl = ['Basi da rivedere','Lacune importanti','Base discreta','Buona preparazione','Molto bene','Ottimo','Quasi pronto','Preparazione avanzata','Pronto'];
  var msg = [
    'Riparti dalle basi con metodo. Ogni lacuna coperta, ogni argomento chiaro.',
    'Consolida le aree deboli prima che sia la commissione a trovarle.',
    'Con il programma completo nessun argomento resta scoperto.',
    "L'inglese tecnico e la simulazione orale con Alessandro fanno la differenza.",
    'Chiudi le ultime lacune e presentati senza incertezze.',
    'Con Alessandro simuli l\'orale e arrivi alla commissione senza sorprese.',
    '20 ore con chi conosce ogni angolo dell\'esame. Niente piu da lasciare al caso.',
    'Presentati e supera.',
    'Simulazione finale, feedback reale. Poi vai e prendi il patentino.'
  ];
  document.getElementById('RSCORE').textContent = s + '/8';
  document.getElementById('RLABEL').textContent = lbl[Math.min(s, 8)];
  document.getElementById('RMSG').textContent   = msg[Math.min(s, 8)];
  var bd   = document.getElementById('RBD');
  var keys = Object.keys(QZ.cats);
  var h    = '<p style="font-family:JetBrains Mono,monospace;font-size:10px;color:var(--orange);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px;">// dettaglio aree</p>';
  for (var i = 0; i < keys.length; i++) {
    var d  = QZ.cats[keys[i]];
    var ok = d.ok === d.n;
    h += '<div style="display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid rgba(143,163,192,0.08);">'
      +  '<span style="color:' + (ok ? '#7fc9b0' : '#e8660a') + ';">' + (ok ? '&#10003;' : '&#10007;') + '</span>'
      +  '<span style="font-size:13px;color:' + (ok ? '#7fc9b0' : '#8fa3c0') + ';">' + keys[i] + '</span></div>';
  }
  bd.innerHTML = h;
}

function ml_webform_success_41983325() {
  var eg = document.getElementById('QR-email');
  var rc = document.getElementById('QR-content');
  if (eg) eg.style.display = 'none';
  if (rc) { rc.style.display = 'block'; QShowContent(); }
}

// ── ENGINE DIAGRAM ────────────────────────────────────────────────────────────
function EngInit() {
  var parts = document.querySelectorAll('.eng-part');
  if (!parts.length) { setTimeout(EngInit, 300); return; }
  var tips = {
    'Canna Cilindro (Cylinder Liner)': 'Cause di usura della canna cilindro e metodi di misura con il micrometro.',
    'Pistone e Segmenti':              'Gioco ammesso tra segmento e canna. Come si misura e quando si sostituisce?',
    'Albero Motore (Crankshaft)':      "Limiti di flessione albero e misura con il comparatore.",
    'Iniettore (Fuel Injector)':       "Come si verifica l'efficienza di un iniettore? Effetti usura plunger.",
    'Turbocompressore (Turbocharger)': 'Cause di bassa velocita TC e interventi correttivi.',
    'Pompa Olio Lubrificante (LO Pump)': 'Valori normali pressione olio. Conseguenze del calo. Shut-down?',
    'Pompa Combustibile e Purificatore': 'Effetti usura plunger. Parametri operativi del purificatore.',
    'Impianto Raffreddamento (Cooling Water)': 'Temperature normali acqua camicie. Funzionamento scambiatore di calore.'
  };
  for (var i = 0; i < parts.length; i++) {
    (function (p) {
      p.setAttribute('pointer-events', 'all');
      p.style.cursor = 'pointer';
      p.addEventListener('mouseover', function () {
        if (this.getAttribute('data-sel') !== '1') { this.style.filter = 'drop-shadow(0 0 8px rgba(255,160,40,0.7))'; this.style.opacity = '0.85'; }
      });
      p.addEventListener('mouseout', function () {
        if (this.getAttribute('data-sel') !== '1') { this.style.filter = ''; this.style.opacity = '1'; }
      });
      p.addEventListener('click', function (ev) {
        ev.preventDefault(); ev.stopPropagation();
        var all = document.querySelectorAll('.eng-part');
        for (var j = 0; j < all.length; j++) { all[j].removeAttribute('data-sel'); all[j].style.filter = ''; all[j].style.opacity = '1'; }
        this.setAttribute('data-sel', '1');
        this.style.filter = 'drop-shadow(0 0 14px rgba(255,210,60,1))';
        var lbl = this.getAttribute('data-label');
        var nm  = document.getElementById('eng-component-name');
        var dc  = document.getElementById('eng-component-desc');
        var tb  = document.getElementById('eng-exam-tip');
        var tq  = document.getElementById('eng-exam-q');
        if (nm) nm.textContent = '// ' + lbl;
        if (dc) dc.textContent = this.getAttribute('data-desc');
        if (tb && tq) { if (tips[lbl]) { tb.style.display = 'block'; tq.textContent = tips[lbl]; } else tb.style.display = 'none'; }
      });
    })(parts[i]);
  }
}

document.addEventListener('DOMContentLoaded', function () {
  QDraw();
  EngInit();
});

